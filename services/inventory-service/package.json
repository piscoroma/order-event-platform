{
   "name": "@order-event-platform/inventory-service",
   "version": "1.0.0",
   "type": "commonjs",
   "main": "src/server.js",
   "scripts": {
      "start": "node src/server.js",
      "dev": "nodemon src/server.js",
      "seed": "node scripts/seed.js",
      "test": "jest",
      "test:watch": "jest --watch",
      "test:integration": "jest --config jest.integration.config.js"
   },
   "dependencies": {
      "@order-event-platform/shared": "*",
      "awilix": "^13.0.3",
      "dotenv": "^17.4.2",
      "express": "^5.2.1",
      "mongoose": "^9.6.2",
      "prom-client": "^15.1.3"
   },
   "devDependencies": {
      "jest": "^29.7.0",
      "mongodb-memory-server": "^11.0.1",
      "nodemon": "^3.1.14"
   },
   "jest": {
      "testMatch": [
         "**/tests/**/*.test.js"
      ],
      "setupFilesAfterEnv": [
         "./tests/setup.js"
      ]
   }
}
