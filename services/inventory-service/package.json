      "test:watch": "jest --watch"
   },
   "dependencies": {
      "awilix": "^10.0.0",
      "dotenv": "^17.3.1",
      "express": "^4.18.2",
      "mongoose": "^8.0.0",
      "nats": "^2.18.0",
      "prom-client": "^15.1.0",
      "winston": "^3.11.0"
   },
   "devDependencies": {
      "jest": "^29.7.0",
      "mongodb-memory-server": "^11.0.1",
      "nodemon": "^3.1.14"
   },
   "jest": {
      "testMatch": [
         "**/tests/**/*.test.js"
      ],
      "setupFilesAfterEnv": [
         "./tests/setup.js"
      ]
