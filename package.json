{
   "name": "order-event-platform",
   "version": "1.0.0",
   "private": true,
   "workspaces": [
      "shared",
      "services/*"
   ],
   "scripts": {
      "test": "npm run test --workspaces --if-present",
      "build": "npm run build --workspaces --if-present",
      "dev:auth": "npm run dev --workspace=@order-event-platform/auth-service",
      "dev:inventory": "npm run dev --workspace=@order-event-platform/inventory-service",
      "lint": "eslint ."
   },
   "devDependencies": {
      "@eslint/js": "^10.0.1",
      "eslint": "^10.6.0",
      "eslint-plugin-n": "^18.2.1",
      "globals": "^17.7.0"
   }
}
